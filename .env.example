# Base44 platform
VITE_BASE44_APP_ID=your_base44_app_id
VITE_BASE44_APP_BASE_URL=https://your-base44-url

# Supabase – copy these from Project Settings → API in the Supabase dashboard
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Azure Blob Storage (from Terraform outputs or Azure Portal)
VITE_AZURE_STORAGE_ACCOUNT_NAME=your_storage_account_name
VITE_AZURE_STORAGE_CONTAINER_NAME=user-media
VITE_AZURE_STORAGE_SAS_TOKEN=your_sas_token

# Azure Communication Services
VITE_AZURE_COMMUNICATION_ENDPOINT=https://your-comms-service.communication.azure.com

# Azure Application Insights
VITE_AZURE_APP_INSIGHTS_CONNECTION_STRING=InstrumentationKey=...

# App domain
VITE_APP_DOMAIN=https://memory-mirror.app
